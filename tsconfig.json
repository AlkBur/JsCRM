{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "types": ["bun"]
  },
  "exclude": ["src/legacy", "tests/legacy"],
  "include": [
    "src/**/*.ts",
    "lsp/**/*.ts",
    "metadata/**/*.ts",
    "runtime/**/*.ts",
    "symbols/**/*.ts",
    "builtins/**/*.ts",
    "bench/**/*.ts",
    "tests/**/*.ts",
    "ir/**/*.ts",
    "compat/**/*.ts"
  ]
}
