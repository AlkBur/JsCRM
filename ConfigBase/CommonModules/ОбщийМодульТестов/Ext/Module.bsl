// ========================================================================
// Тесты для базовых примитивов
// ========================================================================

Функция Тест_Булево() 
    Возврат Истина = Ложь; // Ожидается: Ложь
КонецФункции

Функция Тест_Арифметика() 
    Возврат 2 + 2 * 2; // Ожидается: 6
КонецФункции

Функция Тест_Сравнение()
    Возврат (5 > 3) И (1 < 2); // Ожидается: Истина
КонецФункции

Функция Тест_Строки()
    Возврат "a" + "b"; // Ожидается: "ab"
КонецФункции

Функция Тест_Переменная()
    а = 10;
    b = а + 5;
    Возврат b; // Ожидается: 15
КонецФункции

Функция Тест_Структура()
    Стр = Новый Структура("Ключ", 123);
    Возврат Стр.Ключ; // Ожидается: 123
КонецФункции

Функция Тест_СтруктураМногоКлючей()
    Стр = Новый Структура("Ключ1,Ключ2", 10, 20);
    Возврат Стр.Ключ1 + Стр.Ключ2; // Ожидается: 30
КонецФункции

Функция Тест_Массив()
    М = Новый Массив;
    М.Добавить(10);
    М.Добавить(20);
    Возврат М[0] + М[1]; // Ожидается: 30
КонецФункции

Функция Тест_Если() Экспорт
    Сумма = 100;
    Если Сумма > 150 Тогда
        Возврат "Больше";
    ИначеЕсли Сумма > 50 Тогда
        Возврат "Средне";
    Иначе
        Возврат "Меньше";
    КонецЕсли; // Ожидается: "Больше"
КонецФункции

Функция Тест_ДляЦикл()
    Сумма = 0;
    Для Индекс = 1 По 5 Цикл
        Сумма = Сумма + Индекс;
    КонецЦикла;
    Возврат Сумма; // Ожидается: 15
КонецФункции

Функция Тест_ДляКаждогоЦикл()
    М = Новый Массив;
    М.Добавить(1);
    М.Добавить(2);
    М.Добавить(3);
    Сумма = 0;
    Для Каждого Элемент Из М Цикл
        Сумма = Сумма + Элемент;
    КонецЦикла;
    Возврат Сумма; // Ожидается: 6
КонецФункции

Функция Тест_ПокаЦикл()
    i = 1;
    Пока i <= 5 Цикл
        i = i + 1;
    КонецЦикла;
    Возврат i; // Ожидается: 6
КонецФункции

Функция Тест_Процедура() Экспорт
    Объект = Новый Структура("Сумма,НДС", 100, 0);
    ВызватьПроцедуруТест(Объект);
    Возврат Объект.НДС; // Ожидается: 20
КонецФункции

Процедура ВызватьПроцедуруТест(Объект)
    Объект.НДС = Объект.Сумма * 0.2;
КонецПроцедуры

Функция Тест_Функция()
    Возврат Удвоить(10); // Ожидается: 20
КонецФункции

Функция Удвоить(ЗначПерем) Экспорт
    Возврат ЗначПерем * 2;
КонецФункции

Функция Тест_Попытка() Экспорт
    Результат = "Все ОК";
	Попытка
    	ВызватьИсключение "Тестовое исключение";
	Исключение
		Ошибка = ИнформацияОбОшибке();
		Результат = "Возникала ошибка: " + Ошибка.Описание;	
	КонецПопытки;
    Возврат Результат; // "Это ошибка"
КонецФункции


// ========================================================================
// Тесты для комплексных сценариев
// ========================================================================

Функция Тест_ТаблицаЗначений()
    Таблица = Новый ТаблицаЗначений;
    Таблица.Колонки.Добавить("Номенклатура");
    Таблица.Колонки.Добавить("Количество");
    
    Строка = Таблица.Добавить();
    Строка.Номенклатура = "Товар1";
    Строка.Количество = 10;
    
    Строка = Таблица.Добавить();
    Строка.Номенклатура = "Товар2";
    Строка.Количество = 20;
    
    Сумма = 0;
    Для Каждого ТекСтрока Из Таблица Цикл
        Сумма = Сумма + ТекСтрока.Количество;
    КонецЦикла;
    Возврат Сумма; // Ожидается: 30
КонецФункции

Функция Тест_СтруктураВложенная()
    Внутри = Новый Структура("Значение", 100);
    Стр = Новый Структура("Внешнее, Внутреннее", 50, Внутри);
    Возврат Стр.Внутреннее.Значение + Стр.Внешнее; // Ожидается: 150
КонецФункции

Функция Тест_Даты()
    Дата1 = Дата("20240101");
    Дата2 = Дата("20240110164500");
    Разница = Дата2 - Дата1;
    Возврат Разница; // Ожидается: 9
КонецФункции

// ========================================================================
// Главная функция выполнения тестов
// ========================================================================

Функция _IR_ВыполнитьТесты() Экспорт
	ДанныеДляJSON  = Новый Структура("module, generatedAt, tests",
		"ОбщийМодуль.ОбщийМодульТестов", ТекущаяДатаСеанса(), Новый Массив);
	
	_IR_ВыполнитьТест(ДанныеДляJSON.tests, "Тест_Булево");
	_IR_ВыполнитьТест(ДанныеДляJSON.tests, "Тест_Арифметика");
	_IR_ВыполнитьТест(ДанныеДляJSON.tests, "Тест_Сравнение");
	_IR_ВыполнитьТест(ДанныеДляJSON.tests, "Тест_Строки");
	_IR_ВыполнитьТест(ДанныеДляJSON.tests, "Тест_Переменная");
	_IR_ВыполнитьТест(ДанныеДляJSON.tests, "Тест_Структура");
	_IR_ВыполнитьТест(ДанныеДляJSON.tests, "Тест_СтруктураМногоКлючей");
	_IR_ВыполнитьТест(ДанныеДляJSON.tests, "Тест_Массив");
	_IR_ВыполнитьТест(ДанныеДляJSON.tests, "Тест_Если");
	_IR_ВыполнитьТест(ДанныеДляJSON.tests, "Тест_ДляЦикл");
	_IR_ВыполнитьТест(ДанныеДляJSON.tests, "Тест_ДляКаждогоЦикл");
	_IR_ВыполнитьТест(ДанныеДляJSON.tests, "Тест_ПокаЦикл");
	_IR_ВыполнитьТест(ДанныеДляJSON.tests, "Тест_Процедура");
	_IR_ВыполнитьТест(ДанныеДляJSON.tests, "Тест_Функция");
	_IR_ВыполнитьТест(ДанныеДляJSON.tests, "Тест_Попытка");
	_IR_ВыполнитьТест(ДанныеДляJSON.tests, "Тест_ТаблицаЗначений");
	_IR_ВыполнитьТест(ДанныеДляJSON.tests, "Тест_СтруктураВложенная");
	_IR_ВыполнитьТест(ДанныеДляJSON.tests, "Тест_Даты");

	Возврат ДанныеДляJSON;		
КонецФункции

Процедура _IR_ВыполнитьТест(tests, ИмяТеста) Экспорт
	
	tests.Добавить(Новый Структура("name, result", 
		ИмяТеста, Вычислить(ИмяТеста+"()")));
			
КонецПроцедуры

