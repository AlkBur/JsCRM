	С2.Товар = "Другой";
	С2.Цвет = "Иск";

	НайденнаяСтрока = ТЗ.Найти("Иск", "Товар, Цвет");
	ПроверитьЛожь(НайденнаяСтрока = Неопределено, "Должна находиться строка по совпадению в колонке «Товар»");
	ПроверитьРавенство(НайденнаяСтрока, С1, "При совпадении в первой колонке раньше по порядку — первая строка");

	НайденнаяСтрока = ТЗ.Найти("Синий", "Товар, Цвет");
	ПроверитьИстину(НайденнаяСтрока = Неопределено, "Нет совпадений ни в одной из колонок");

	С3 = ТЗ.Добавить();
	С3.Товар = "Третий";
	С3.Цвет = "Синий";

	НайденнаяСтрока = ТЗ.Найти("Синий", "Товар, Цвет");
	ПроверитьЛожь(НайденнаяСтрока = Неопределено, "Совпадение только в проиндексированной колонке «Цвет»");
	ПроверитьРавенство(НайденнаяСтрока, С3);

КонецПроцедуры

Процедура ТестДолжен_НайтиСИндексомБыстрееЧемБезИндекса() Экспорт

	КоличествоСтрок = 10000;
	КоличествоИзмерений = 100;

	ТЗ = Новый ТаблицаЗначений();
	ТЗ.Колонки.Добавить("СИндексом");
	ТЗ.Колонки.Добавить("БезИндекса");
	ТЗ.Индексы.Добавить("СИндексом");

	ИскомоеЗначение = Неопределено;
	Для к = 1 По КоличествоСтрок Цикл
		UID = Новый УникальныйИдентификатор();
		Стр = ТЗ.Добавить();
		Стр.СИндексом  = Строка(UID);
		Стр.БезИндекса = Строка(UID);
		Если к = КоличествоСтрок / 2 Тогда
			ИскомоеЗначение = Строка(UID);
		КонецЕсли;
	КонецЦикла;

	// Замер поиска БЕЗ индекса
	НачалоБезИндекса = ТекущаяУниверсальнаяДатаВМиллисекундах();
	Для Ит = 1 По КоличествоИзмерений Цикл
		ТЗ.Найти(ИскомоеЗначение, "БезИндекса");
	КонецЦикла;
	ВремяБезИндекса = ТекущаяУниверсальнаяДатаВМиллисекундах() - НачалоБезИндекса;

	// Замер поиска С индексом
	НачалоСИндексом = ТекущаяУниверсальнаяДатаВМиллисекундах();
	Для Ит = 1 По КоличествоИзмерений Цикл
		ТЗ.Найти(ИскомоеЗначение, "СИндексом");
	КонецЦикла;
	ВремяСИндексом = ТекущаяУниверсальнаяДатаВМиллисекундах() - НачалоСИндексом;

	ПроверитьИстину(
		ВремяСИндексом < ВремяБезИндекса,
		"Поиск с индексом (" + ВремяСИндексом + " мс) должен быть быстрее поиска без индекса (" + ВремяБезИндекса + " мс)"
	);

КонецПроцедуры

&НаСервере
Процедура ПроверитьНеравенство(Значение1, Значение2, Знач Комментарий="")
	Если Не ПустаяСтрока(Комментарий) Тогда
		Комментарий = " ("+Комментарий+")";
	КонецЕсли;
	ТексДляШаблона = "%1) %2 %3 %4%5";	
	
	
	НомерТеста = НомерТеста + 1;
	Если Значение1 = Значение2 Тогда
		СообщитьJSON(СтрШаблон(ТексДляШаблона, НомерТеста, Значение1, "=",
			Значение2, Комментарий));
	Иначе
		СообщитьJSON(СтрШаблон(ТексДляШаблона, НомерТеста, Значение1, "<>",
			Значение2, Комментарий));
	КонецЕсли;
КонецПроцедуры

