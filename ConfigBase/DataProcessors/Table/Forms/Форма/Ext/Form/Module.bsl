Процедура ТестДолжен_НайтиИспользуетИндекс() Экспорт

	ТЗ = Новый ТаблицаЗначений();
	ТЗ.Колонки.Добавить("СИндексом");
	ТЗ.Колонки.Добавить("БезИндекса");
	ТЗ.Индексы.Добавить("СИндексом");

	КоличествоСтрок = 1000;
	Для к = 0 По КоличествоСтрок - 1 Цикл
		Стр = ТЗ.Добавить();
		Стр.СИндексом  = "Ключ" + Формат(к, "ЧГ=");
		Стр.БезИндекса = "Ключ" + Формат(к, "ЧГ=");
	КонецЦикла;

	// Поиск существующего значения по проиндексированной колонке
	ИскомыйКлюч = "Ключ" + Формат(КоличествоСтрок / 2, "ЧГ=");
	НайденнаяСтрока = ТЗ.Найти(ИскомыйКлюч, "СИндексом");
	ПроверитьЛожь(НайденнаяСтрока = Неопределено, "Строка должна быть найдена по проиндексированной колонке");
	ПроверитьРавенство(НайденнаяСтрока.СИндексом, ИскомыйКлюч, "Найденная строка должна содержать искомое значение");

	// Поиск несуществующего значения по проиндексированной колонке
	НесуществующийКлюч = "Ключ" + Формат(КоличествоСтрок + 1, "ЧГ=");
	НайденнаяСтрока = ТЗ.Найти(НесуществующийКлюч, "СИндексом");
	ПроверитьИстину(НайденнаяСтрока = Неопределено, "Несуществующее значение не должно быть найдено по проиндексированной колонке");

