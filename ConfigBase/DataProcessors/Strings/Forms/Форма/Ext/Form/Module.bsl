&НаКлиенте
Функция Инициализация()
	Данные = 
	"
	|Стр2
	|Стр3
	|Стр4
	|
	|Стр6
	|Стр7
	|Стр8
	|
	|Стр10";
	
	Возврат Данные;
КонецФункции

&НаКлиенте
Процедура ТестДолжен_ВернутьСтроку1() Экспорт
	Данные = Инициализация();

	Стр = СтрПолучитьСтроку(Данные, 1);

	//ПроверитьРавенство("", Стр);
	Сообщить("1: " + Стр)
КонецПроцедуры

