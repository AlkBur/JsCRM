    ПроверитьРавенство("Значение для Дата1", Соотв[Дата1]);
    ПроверитьРавенство("Значение для Дата2", Соотв[Дата2]);
    
КонецПроцедуры

Процедура ТестДолжен_ПроверитьКлючУникальныйИдентификаторВСоответствии() Экспорт
    
    Соотв = Новый Соответствие;
    УИД1 = Новый УникальныйИдентификатор;
    УИД2 = Новый УникальныйИдентификатор;
    
    Соотв.Вставить(УИД1, "Значение для УИД1");
    Соотв.Вставить(УИД2, "Значение для УИД2");
    
    ПроверитьРавенство(2, Соотв.Количество());
    ПроверитьРавенство("Значение для УИД1", Соотв[УИД1]);
    ПроверитьРавенство("Значение для УИД2", Соотв[УИД2]);
    
КонецПроцедуры

Процедура ТестДолжен_ПроверитьКлючТипВСоответствии() Экспорт
    
    Соотв = Новый Соответствие;
    Тип1 = Тип("Строка");
    Тип2 = Тип("Число");
    
    Соотв.Вставить(Тип1, "Значение для Тип Строка");
    Соотв.Вставить(Тип2, "Значение для Тип Число");
    
    ПроверитьРавенство(2, Соотв.Количество());
    ПроверитьРавенство("Значение для Тип Строка", Соотв[Тип1]);
    ПроверитьРавенство("Значение для Тип Число", Соотв[Тип2]);
    
КонецПроцедуры

Процедура ТестДолжен_ПроверитьРазличныеКлючиВСоответствии() Экспорт
    
    // Проверка, что различные типы значений могут быть одновременно ключами
    Соотв = Новый Соответствие;
    
    Соотв[Неопределено] = "Неопределено";
    Соотв[Null] = "Null";
    Соотв[Истина] = "Истина";
    Соотв[42] = "Число";
    Соотв["Текст"] = "Строка";
    Соотв['20240101'] = "Дата";
    Соотв[Тип("Строка")] = "Тип";
    
    ПроверитьРавенство(7, Соотв.Количество());
    ПроверитьРавенство("Неопределено", Соотв[Неопределено]);
    ПроверитьРавенство("Null", Соотв[Null]);
    ПроверитьРавенство("Истина", Соотв[Истина]);
    ПроверитьРавенство("Число", Соотв[42]);
    ПроверитьРавенство("Строка", Соотв["Текст"]);
    ПроверитьРавенство("Дата", Соотв['20240101']);
    ПроверитьРавенство("Тип", Соотв[Тип("Строка")]);
    
КонецПроцедуры


Процедура ПроверитьРавенство(Значение1, Значение2)
	Если Значение1 = Значение2 Тогда
		Сообщить("" +Значение1 + " = " + Значение2);
	Иначе
		Сообщить("" +Значение1 + " <> " + Значение2);
	КонецЕсли;
КонецПроцедуры
