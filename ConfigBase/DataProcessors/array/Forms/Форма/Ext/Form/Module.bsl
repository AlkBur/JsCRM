	Соответствие = Новый Соответствие;
	Соответствие.Вставить("Ключ1", "Значение1");
	
	ФиксированноеСоответствие = Новый ФиксированноеСоответствие(Соответствие);
	
	ПроверитьРавенство(ТипЗнч(ФиксированноеСоответствие), Тип("ФиксированноеСоответствие"));
	ПроверитьРавенство(ФиксированноеСоответствие.Количество(), Соответствие.Количество());
	
