Процедура ТестДолжен_ПроверитьЧтоПолучениеНесуществующегоКлючаНеВызываетОшибки() Экспорт

	Соответствие = Новый Соответствие;
	ФиксированноеСоответствие = Новый ФиксированноеСоответствие(Соответствие);
	
	Значение = ФиксированноеСоответствие.Получить("Заведомо отсутствующий ключ");
	ПроверитьРавенство(Значение, Неопределено);

КонецПроцедуры

&НаКлиенте
Процедура ПроверитьРавенство(Значение1, Значение2)
	НомерТеста = НомерТеста + 1;
	Если Значение1 = Значение2 Тогда
		Сообщить("" +НомерТеста + ") "+Значение1 + " = " + Значение2);
	Иначе
		Сообщить("" +НомерТеста + ") " +Значение1 + " <> " + Значение2);
	КонецЕсли;
КонецПроцедуры
